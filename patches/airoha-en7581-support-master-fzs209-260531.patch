+						E('th',{'class':'th'},_('Original Flow')), E('th',{'class':'th'},_('New Flow')), E('th',{'class':'th'},_('Ethernet'))
+					])
+				].concat(renderPpeRows(entries)))
+			])
+		]);
+
+		poll.add(L.bind(function() {

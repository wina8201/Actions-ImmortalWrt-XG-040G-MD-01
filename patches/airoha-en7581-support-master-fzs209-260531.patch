++	if (old_chg & CPUPLL_CHG_BIT)
++		writel(cleared | FIELD_PREP(CPUPLL_CHG_POSDIV_MASK, posdiv),
++		       base + CPUPLL_SDM_PCW_CHG);
++	else
++		writel(cleared | FIELD_PREP(CPUPLL_CHG_POSDIV_MASK, posdiv) |
++		       CPUPLL_CHG_BIT, base + CPUPLL_SDM_PCW_CHG);

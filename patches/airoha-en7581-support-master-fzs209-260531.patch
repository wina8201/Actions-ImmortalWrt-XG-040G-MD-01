+		E('div', { 'style': 'display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px' }, [
+			cdmCard('cdm1', 'CDM1', 'CPU DMA 1', 'P0'),
+			cdmCard('cdm2', 'CDM2', 'CPU DMA 2', 'P5'),
+			cdm4WiFi
+		]),

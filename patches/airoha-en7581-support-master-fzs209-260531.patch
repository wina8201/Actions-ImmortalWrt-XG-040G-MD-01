+
+function renderPPPoEOffloadSelect(enabled) {
+	var cur = enabled ? '1' : '0';
+	return E('select', { 'id': 'pppoe-offload-select', 'class': 'cbi-input-select', 'style': 'min-width:140px', 'change': function(ev) {
+		var v = parseInt(ev.target.value);

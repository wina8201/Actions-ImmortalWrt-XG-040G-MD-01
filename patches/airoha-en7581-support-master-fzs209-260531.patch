+				if(tb){while(tb.rows.length>1)tb.deleteRow(1);renderPpeRows(entries).forEach(function(r){tb.appendChild(r);});}
+			},this));
+		},this), 5);
+
+		return view;
+	},
+
+	handleSaveApply: null, handleSave: null, handleReset: null
+});
